function applyF(){
  const q=document.getElementById('fSearch').value.toLowerCase().trim();
  const rate=document.getElementById('fRate').value;
  const size=document.getElementById('fSize').value;
  const fRegEl=document.getElementById('fRegion');
  const _rawKey=fRegEl?fRegEl.value:'';
  activeRegion=_rawKey?REGION_KEY_MAP[_rawKey]||_rawKey:'';

  // Priority: country > region > all
  let sourceData;
  if(activeCountry&&BY_COUNTRY_DEPT[activeCountry]){
    sourceData=sanitizePos(BY_COUNTRY_DEPT[activeCountry]);
  } else if(activeRegion&&BY_REGION_DEPT[activeRegion]){
    sourceData=sanitizePos(BY_REGION_DEPT[activeRegion]);
  } else {
    sourceData=sanitizePos(byPos);
  }

  filtered=sourceData.filter(w=>{
    if(rate==='0'&&w.completion_rate!==0)return false;
    if(rate==='low'&&(w.completion_rate===0||w.completion_rate>=30))return false;
    if(rate==='mid'&&(w.completion_rate<30||w.completion_rate>70))return false;
    if(rate==='high'&&w.completion_rate<=70)return false;
    if(size==='1'&&w.headcount!==1)return false;
    if(size==='small'&&(w.headcount<2||w.headcount>5))return false;
    if(size==='large'&&w.headcount<6)return false;
    if(q&&!w.position.toLowerCase().includes(q))return false;
    return true;
  });
  doSort();page=1;render();
}
