/* ══════ SNAPSHOT LOAD / RESTORE ══════ */
let _liveByPos=null, _liveCities=null, _liveCountries=null, _liveRegions=null, _liveCourses=null;
let _isViewingSnapshot=false;

function loadSnapshot(idx){
  const snap=HISTORY[idx];
  if(!snap){return;}
  // Save live state if not already in snapshot mode
  if(!_isViewingSnapshot){
    _liveByPos=JSON.stringify(byPos);
    _liveCities=JSON.stringify(CITY_DATA);
    _liveCountries=JSON.stringify(COUNTRY_DATA);
    _liveRegions=JSON.stringify(REGION_DATA);
    _liveCourses=JSON.stringify(COURSE_DETAIL);
  }
  _isViewingSnapshot=true;
  // Restore snapshot data
  try{
    if(snap.byPos){byPos=sanitizePos(JSON.parse(snap.byPos));}
    if(snap.cities){while(CITY_DATA.length)CITY_DATA.pop();JSON.parse(snap.cities).forEach(function(c){CITY_DATA.push(c);});}
    if(snap.countries){while(COUNTRY_DATA.length)COUNTRY_DATA.pop();JSON.parse(snap.countries).forEach(function(c){COUNTRY_DATA.push(c);});}
    if(snap.regions){while(REGION_DATA.length)REGION_DATA.pop();JSON.parse(snap.regions).forEach(function(r){REGION_DATA.push(r);});}
    if(snap.courses){while(COURSE_DETAIL.length)COURSE_DETAIL.pop();JSON.parse(snap.courses).forEach(function(c){COURSE_DETAIL.push(c);});}
  }catch(e){console.error('Snapshot load error:',e);}
  filtered=[...byPos];doSort();page=1;
  // Show banner
  const banner=document.getElementById('snapBanner');
  if(banner){
    banner.style.display='flex';
    document.getElementById('snapLabel').textContent=snap.date+' '+snap.time+(snap.label?' — '+snap.label:'');
  }
  // Re-render everything
  render();
  // Close history panel
  closeHist();
}

function restoreLive(){
  if(!_isViewingSnapshot)return;
  try{
    if(_liveByPos)byPos=JSON.parse(_liveByPos);
    if(_liveCities){while(CITY_DATA.length)CITY_DATA.pop();JSON.parse(_liveCities).forEach(function(c){CITY_DATA.push(c);});}
    if(_liveCountries){while(COUNTRY_DATA.length)COUNTRY_DATA.pop();JSON.parse(_liveCountries).forEach(function(c){COUNTRY_DATA.push(c);});}
    if(_liveRegions){while(REGION_DATA.length)REGION_DATA.pop();JSON.parse(_liveRegions).forEach(function(r){REGION_DATA.push(r);});}
    if(_liveCourses){while(COURSE_DETAIL.length)COURSE_DETAIL.pop();JSON.parse(_liveCourses).forEach(function(c){COURSE_DETAIL.push(c);});}
  }catch(e){}
  _isViewingSnapshot=false;
  filtered=[...byPos];doSort();page=1;
  const banner=document.getElementById('snapBanner');
  if(banner)banner.style.display='none';
  render();
}


