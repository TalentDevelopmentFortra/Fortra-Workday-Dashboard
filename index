function groupByPeriod(snaps,view){
  const map={};
  snaps.forEach(function(s){
    let key;
    const d=new Date(s.ts);
    if(view==='week'){
      const start=new Date(d);start.setDate(d.getDate()-d.getDay());
      key='Wk '+start.toLocaleDateString('en-US',{month:'short',day:'numeric'});
    }else{
      key=d.toLocaleDateString('en-US',{month:'short',day:'numeric'});
    }
    if(!map[key])map[key]=[];
    map[key].push(s);
  });
  return Object.entries(map).map(function(e){
    const v=e[1];
    const avg=function(f){return+(v.reduce(function(s,x){return s+x[f];},0)/v.length).toFixed(1);};
    return{label:e[0],completion_rate:avg('completion_rate'),completed:Math.round(avg('completed')),enrollments:Math.round(avg('enrollments'))};
  });
}

