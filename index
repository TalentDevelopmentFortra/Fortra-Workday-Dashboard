function buildSnapshot(){
  const now=new Date();
  const _totE=byPos.reduce((s,w)=>s+w.enrollments,0);
  const _totC=byPos.reduce((s,w)=>s+w.completed,0);
  const avgRate=_totE>0?+(_totC/_totE*100).toFixed(1):0;
  return{
    ts:now.getTime(),
    date:now.toLocaleDateString('en-US',{year:'numeric',month:'2-digit',day:'2-digit'}),
    time:now.toLocaleTimeString(),
    label:'',
    roles:byPos.length,
    employees:byPos.reduce((s,w)=>s+w.headcount,0),
    enrollments:_totE,
    completed:_totC,
    completion_rate:avgRate,
    byPos:JSON.stringify(byPos),
    cities:JSON.stringify(CITY_DATA),
    countries:JSON.stringify(COUNTRY_DATA),
    regions:JSON.stringify(REGION_DATA),
    courses:JSON.stringify(COURSE_DETAIL),
  };
}

