function parseWorkdayExcel(rows){
  var headerRow=null,headerIdx=0;
  for(var i=0;i<Math.min(5,rows.length);i++){
    if(rows[i]&&rows[i].some(function(c){return String(c).trim()==='Worker';})){
      headerRow=rows[i];headerIdx=i;break;
    }
  }
  if(!headerRow)return null;
  var cols={};
  headerRow.forEach(function(h,i){cols[String(h).trim()]=i;});
  if(cols['Worker']===undefined||cols['Learning Content Title']===undefined)return null;

  var LOC_MAP={'Argentina':{country:'Argentina',city:'Buenos Aires',region:'LATAM'},'Armenia-Yerevan Office':{country:'Armenia',city:'Yerevan',region:'EMEA'},'Australia':{country:'Australia',city:'Sydney',region:'APAC'},'Canada-British Columbia':{country:'Canada',city:'Vancouver',region:'North America'},'Canada-Ontario':{country:'Canada',city:'Ontario',region:'North America'},'Canada-Quebec':{country:'Canada',city:'Quebec',region:'North America'},'Colombia':{country:'Colombia',city:'Bogota',region:'LATAM'},'India':{country:'India',city:'Bangalore',region:'APAC'},'Mexico':{country:'Mexico',city:'Mexico City',region:'LATAM'},'Saudi Arabia':{country:'Saudi Arabia',city:'Riyadh',region:'APAC'},'Spain':{country:'Spain',city:'Madrid',region:'EMEA'},'Sweden-Uppsala Office':{country:'Sweden',city:'Uppsala',region:'EMEA'},'Taiwan':{country:'Taiwan',city:'Taipei',region:'APAC'},'US-ARIZONA':{country:'United States',city:'Arizona',region:'North America'},'US-CALIFORNIA':{country:'United States',city:'California',region:'North America'},'US-COLORADO':{country:'United States',city:'Colorado',region:'North America'},'US-CONNECTICUT':{country:'United States',city:'Connecticut',region:'North America'},'US-DELAWARE':{country:'United States',city:'Delaware',region:'North America'},'US-GEORGIA':{country:'United States',city:'Georgia',region:'North America'},'US-ILLINOIS':{country:'United States',city:'Illinois',region:'North America'},'US-IOWA':{country:'United States',city:'Iowa',region:'North America'},'US-KANSAS':{country:'United States',city:'Kansas',region:'North America'},'US-MAINE':{country:'United States',city:'Maine',region:'North America'},'US-MARYLAND':{country:'United States',city:'Maryland',region:'North America'},'US-MASSACHUSETTS':{country:'United States',city:'Massachusetts',region:'North America'},'US-MICHIGAN':{country:'United States',city:'Michigan',region:'North America'},'US-MINNESOTA':{country:'United States',city:'Minnesota',region:'North America'},'US-MINNESOTA-EP HQ':{country:'United States',city:'Minnesota (HQ)',region:'North America'},'US-NEBRASKA':{country:'United States',city:'Nebraska',region:'North America'},'US-NEVADA':{country:'United States',city:'Nevada',region:'North America'},'US-NEW JERSEY':{country:'United States',city:'New Jersey',region:'North America'},'US-OHIO':{country:'United States',city:'Ohio',region:'North America'},'US-OREGON':{country:'United States',city:'Oregon',region:'North America'},'US-SOUTH CAROLINA':{country:'United States',city:'South Carolina',region:'North America'},'US-TENNESSEE':{country:'United States',city:'Tennessee',region:'North America'},'US-TEXAS':{country:'United States',city:'Texas',region:'North America'},'US-WISCONSIN':{country:'United States',city:'Wisconsin',region:'North America'},'United Arab Emirates':{country:'UAE',city:'Dubai',region:'EMEA'},'United Kingdom':{country:'United Kingdom',city:'London',region:'EMEA'}};
  var statusCol=cols['Completion Status']!==undefined?'Completion Status':'Completed';
  var ccCol=cols['CF LRV Cost Center']!==undefined?'CF LRV Cost Center':null;
  var durCol=cols['Course Duration']!==undefined?'Course Duration':null;
  var locCol=cols["Worker's Location"]!==undefined?"Worker's Location":null;

  var recs=[];
  for(var ri=headerIdx+1;ri<rows.length;ri++){
    var row=rows[ri];
    if(!row||!row[cols['Worker']])continue;
    var worker=String(row[cols['Worker']]).trim();
    if(!worker||worker==='nan'||worker.indexOf('Terminated')>=0)continue;
    var loc=locCol?String(row[cols[locCol]]||'').trim():'Unknown';
    var lm=LOC_MAP[loc]||{country:'Unknown',city:'Unknown',region:'Unknown'};
    var ccRaw=ccCol?String(row[cols[ccCol]]||'N/A').trim():'N/A';
    var pos=ccRaw!=='N/A'&&ccRaw!=='nan'&&ccRaw.indexOf(' ')>=0?ccRaw.split(' ').slice(1).join(' '):ccRaw;
    if(!pos||pos==='N/A'||pos==='nan')continue;
    var course=String(row[cols['Learning Content Title']]||'').trim();
    var statusVal=String(row[cols[statusCol]]||'').trim();
    var durMin=durCol?parseInt(row[cols[durCol]]||0)||0:0;
    recs.push({worker:worker,country:lm.country,city:lm.city,region:lm.region,
      position:pos,course:course,duration_min:durMin,
      completed:statusVal==='Completed'?1:0,
      in_progress:statusVal==='In Progress'?1:0,
      not_started:statusVal==='Not Started'?1:0});
  }
  if(!recs.length)return null;

  function aggBy(key,extra){
    var m={};
    recs.forEach(function(r){
      var k=r[key];if(!k||k==='Unknown')return;
      if(!m[k])m[k]={workers:new Set(),enrollments:0,completed:0,in_progress:0,not_started:0,total_minutes:0};
      if(extra)extra.forEach(function(ek){if(!m[k][ek])m[k][ek]=r[ek];});
      m[k].workers.add(r.worker);m[k].enrollments++;
      m[k].completed+=r.completed;m[k].in_progress+=r.in_progress;
      m[k].not_started+=r.not_started;m[k].total_minutes+=r.duration_min;
    });
    return Object.entries(m).map(function(e){
      var v=e[1],rate=v.enrollments>0?+(v.completed/v.enrollments*100).toFixed(1):0;
      var obj={employees:v.workers.size,enrollments:v.enrollments,completed:v.completed,
        in_progress:v.in_progress,not_started:v.not_started,completion_rate:rate,total_minutes:v.total_minutes};
      if(extra)extra.forEach(function(ek){obj[ek]=v[ek]||'';});
      obj[key]=e[0];
      return obj;
    }).sort(function(a,b){return b.enrollments-a.enrollments;});
  }

  var newByPos=aggBy('position');
  var totalW=new Set(recs.map(function(r){return r.worker;})).size;
  var newCountries=aggBy('country');
  newCountries.forEach(function(c){c.activity_score=c.enrollments+c.completed*2;});

  var cityMap={};
  recs.forEach(function(r){
    var k=r.city;if(!k||k==='Unknown')return;
    if(!cityMap[k])cityMap[k]={city:k,country:r.country,region:r.region,workers:new Set(),enrollments:0,completed:0,in_progress:0,not_started:0,total_minutes:0};
    cityMap[k].workers.add(r.worker);cityMap[k].enrollments++;
    cityMap[k].completed+=r.completed;cityMap[k].in_progress+=r.in_progress;
    cityMap[k].not_started+=r.not_started;cityMap[k].total_minutes+=r.duration_min;
  });
  var newCities=Object.values(cityMap).map(function(v){
    var rate=v.enrollments>0?+(v.completed/v.enrollments*100).toFixed(1):0;
    return{city:v.city,country:v.country,region:v.region,employees:v.workers.size,
      enrollments:v.enrollments,completed:v.completed,in_progress:v.in_progress,
      not_started:v.not_started,completion_rate:rate,
      activity_score:v.enrollments+v.completed*2,total_minutes:v.total_minutes};
  }).sort(function(a,b){return b.completed-a.completed;});

  var newCountryCities={};
  newCities.forEach(function(c){if(!newCountryCities[c.country])newCountryCities[c.country]=[];newCountryCities[c.country].push(c);});

  var regionMap={};
  recs.forEach(function(r){
    var reg=r.region;if(!reg||reg==='Unknown')return;
    if(!regionMap[reg])regionMap[reg]={region:reg,workers:new Set(),enrollments:0,completed:0,in_progress:0,not_started:0,total_minutes:0};
    regionMap[reg].workers.add(r.worker);regionMap[reg].enrollments++;
    regionMap[reg].completed+=r.completed;regionMap[reg].in_progress+=r.in_progress;
    regionMap[reg].not_started+=r.not_started;regionMap[reg].total_minutes+=r.duration_min;
  });
  var RORDER=['North America','LATAM','EMEA','APAC'];
  var newRegions=RORDER.filter(function(r){return regionMap[r];}).map(function(reg){
    var v=regionMap[reg],rate=v.enrollments>0?+(v.completed/v.enrollments*100).toFixed(1):0;
    return{region:reg,employees:v.workers.size,enrollments:v.enrollments,completed:v.completed,
      in_progress:v.in_progress,not_started:v.not_started,completion_rate:rate,
      pct_of_total:totalW>0?+(v.workers.size/totalW*100).toFixed(1):0,total_minutes:v.total_minutes};
  });

  function aggRegionDept(regKey){
    var m={};
    recs.filter(function(r){return r[regKey]==='Unknown'?false:true;}).forEach(function(r){
      var regVal=r[regKey];var dept=r.position;
      if(!m[regVal])m[regVal]={};
      if(!m[regVal][dept])m[regVal][dept]={position:dept,workers:new Set(),enrollments:0,completed:0,in_progress:0,not_started:0,total_minutes:0};
      m[regVal][dept].workers.add(r.worker);m[regVal][dept].enrollments++;
      m[regVal][dept].completed+=r.completed;m[regVal][dept].in_progress+=r.in_progress;
      m[regVal][dept].not_started+=r.not_started;m[regVal][dept].total_minutes+=r.duration_min;
    });
    var result={};
    Object.keys(m).forEach(function(k){
      result[k]=Object.values(m[k]).map(function(v){
        var rate=v.enrollments>0?+(v.completed/v.enrollments*100).toFixed(1):0;
        return{position:v.position,headcount:v.workers?v.workers.size:0,enrollments:v.enrollments||0,
          completed:v.completed,in_progress:v.in_progress,not_started:v.not_started,
          completion_rate:rate,total_minutes:v.total_minutes};
      }).sort(function(a,b){return b.enrollments-a.enrollments;});
    });
    return result;
  }
  var newByRD=aggRegionDept('region');
  var newByCD=aggRegionDept('country');

  var courseMap={};
  recs.forEach(function(r){
    if(!r.course)return;
    if(!courseMap[r.course])courseMap[r.course]={name:r.course,enrolled:0,completed:0,in_progress:0,not_started:0,duration_min:r.duration_min};
    courseMap[r.course].enrolled++;courseMap[r.course].completed+=r.completed;
    courseMap[r.course].in_progress+=r.in_progress;courseMap[r.course].not_started+=r.not_started;
  });
  var newCourses=Object.values(courseMap).sort(function(a,b){return b.enrolled-a.enrolled;});

  return{byPos:newByPos,countries:newCountries,cities:newCities,countryCities:newCountryCities,
    regions:newRegions,byRegionDept:newByRD,byCountryDept:newByCD,courses:newCourses};
}

function readFile(file){
  const d=document.getElementById('fnD');d.textContent='File: '+file.name;d.style.display='';
  document.getElementById('errMsg').style.display='none';
  if(/\.xlsx?$/i.test(file.name)){
    const r=new FileReader();
    r.onerror=function(){document.getElementById('errMsg').textContent='Error reading file. Please try again.';document.getElementById('errMsg').style.display='';};
    r.onloadend=function(ev){
      if(r.readyState!==FileReader.DONE)return;
      try{
        const data=ev.target.result;
        if(!data||!(data instanceof ArrayBuffer)||data.byteLength===0){throw new Error('File could not be read. Please try again.');}
        const arr=new Uint8Array(data);
        const wb=XLSX.read(arr,{type:'array',cellDates:true,cellNF:false,cellText:false});
        // Prefer Sheet1 (Workday format), else first sheet
        const sheetName=wb.SheetNames.indexOf('Sheet1')>=0?'Sheet1':wb.SheetNames[0];
