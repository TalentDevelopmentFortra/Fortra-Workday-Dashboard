function pCSV(line){const res=[];let cur='';let q=false;for(let i=0;i<line.length;i++){const ch=line[i];if(ch==='"'){if(q&&line[i+1]==='"'){cur+='"';i++;}else q=!q;}else if(ch===','&&!q){res.push(cur.trim());cur='';}else cur+=ch;}res.push(cur.trim());return res;}
function loadData(){
  const raw=document.getElementById('csvIn').value.trim();
  const errEl=document.getElementById('errMsg');
  if(!raw){errEl.textContent='Please upload or paste data first.';errEl.style.display='';return;}
  const lines=raw.split('\n').map(function(l){return l.trim();}).filter(Boolean);
  const si=lines[0].toLowerCase().replace(/"/g,'').split(',').some(function(h){return['name','id','employee'].indexOf(h.trim())>=0;})?1:0;
  const recs=[];
  lines.slice(si).forEach(function(line){
    const p=pCSV(line);if(p.length<3||!p[0])return;
    const position=p[1]||'N/A';
    const cRaw=p[2]||'';
    const cc=cRaw.split('|').map(function(c){return c.trim();}).filter(function(c){return c&&c.toLowerCase()!=='total';});
    const completed=parseInt((p[3]||'0').replace(/\D/g,''))||0;
    const other=parseInt((p[4]||'0').replace(/\D/g,''))||0;
    const enrollments=parseInt((p[5]||'0').replace(/\D/g,''))||completed+other;
    const not_started=parseInt((p[6]||'0').replace(/\D/g,''))||0;
    const in_progress=parseInt((p[7]||'0').replace(/\D/g,''))||0;
    recs.push({position:position,completed_courses:cc,completed:completed,enrollments:enrollments,not_started:not_started,in_progress:in_progress});
  });
  if(!recs.length){errEl.textContent='No rows parsed. Check column order.';errEl.style.display='';return;}
  const pm={};
  recs.forEach(function(r){
    if(!pm[r.position])pm[r.position]={position:r.position,headcount:0,enrollments:0,completed:0,in_progress:0,not_started:0};
    pm[r.position].headcount++;pm[r.position].enrollments+=r.enrollments;
    pm[r.position].completed+=r.completed;pm[r.position].in_progress+=r.in_progress;pm[r.position].not_started+=r.not_started;
  });
  const cm={};recs.forEach(function(r){r.completed_courses.forEach(function(c){cm[c]=(cm[c]||0)+1;});});
  byPos=Object.values(pm).map(function(v){return Object.assign({},v,{completion_rate:v.enrollments>0?+(v.completed/v.enrollments*100).toFixed(1):0});}).sort(function(a,b){return b.enrollments-a.enrollments;});
  courses=Object.entries(cm).map(function(e){return{name:e[0],count:e[1]};}).sort(function(a,b){return b.count-a.count;});
  filtered=[...byPos];errEl.style.display='none';page=1;doSort();render();
  document.getElementById('tsUp').textContent='Updated '+new Date().toLocaleTimeString()+' — '+byPos.length+' roles';
  const autoSnap=buildSnapshot();autoSnap.label='Auto — data upload';HISTORY.push(autoSnap);saveToStorage();
  document.getElementById('csvIn').value='';document.getElementById('fnD').style.display='none';document.getElementById('fIn').value='';
  closeUp();
}

